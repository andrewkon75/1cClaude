<?xml version="1.0" encoding="UTF-8"?>
<Module xmlns="http://v8.1c.ru/8.3/managed-application/module" xmlns:ent="http://v8.1c.ru/8.1/data/enterprise" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<Function name="ПроверитьИНН">
		<Parameter name="ИНН">
			<Type>
				<xs:element name="String"/>
			</Type>
		</Parameter>
		<Parameter name="ЮридическоеЛицо">
			<Type>
				<xs:element name="Boolean"/>
			</Type>
		</Parameter>
		<ReturnType>
			<xs:element name="String"/>
		</ReturnType>
		<Body>
			<Line>
				<Val>Если ПустаяСтрока(ИНН) Тогда</Val>
			</Line>
			<Line>
				<Val>	Возврат "";</Val>
			</Line>
			<Line>
				<Val>КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>Если ЮридическоеЛицо Тогда</Val>
			</Line>
			<Line>
				<Val>	// Проверка длины для юрлица</Val>
			</Line>
			<Line>
				<Val>	Если СтрДлина(ИНН) &lt;&gt; 10 Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "ИНН юридического лица должен содержать 10 цифр";</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	// Проверка что только цифры</Val>
			</Line>
			<Line>
				<Val>	Если НЕ ЗначениеЗаполнено(Число(ИНН)) Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "ИНН должен содержать только цифры";</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	// Проверка контрольного разряда (10-й)</Val>
			</Line>
			<Line>
				<Val>	Сумма = Число(Сред(ИНН, 1, 1)) * 2 + Число(Сред(ИНН, 2, 1)) * 4 + Число(Сред(ИНН, 3, 1)) * 10 + Число(Сред(ИНН, 4, 1)) * 3 + Число(Сред(ИНН, 5, 1)) * 5 + Число(Сред(ИНН, 6, 1)) * 9 + Число(Сред(ИНН, 7, 1)) * 4 + Число(Сред(ИНН, 8, 1)) * 6 + Число(Сред(ИНН, 9, 1)) * 8;</Val>
			</Line>
			<Line>
				<Val>	Контрольный = Сумма % 11;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный &gt; 9 Тогда</Val>
			</Line>
			<Line>
				<Val>		Контрольный = Контрольный % 10;</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный &lt;&gt; Число(Сред(ИНН, 10, 1)) Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "Неверный контрольный разряд ИНН. Ожидалось: " + Строка(Контрольный);</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>Иначе</Val>
			</Line>
			<Line>
				<Val>	// Проверка длины для физлица</Val>
			</Line>
			<Line>
				<Val>	Если СтрДлина(ИНН) &lt;&gt; 12 Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "ИНН физического лица должен содержать 12 цифр";</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	// Проверка что только цифры</Val>
			</Line>
			<Line>
				<Val>	Если НЕ ЗначениеЗаполнено(Число(ИНН)) Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "ИНН должен содержать только цифры";</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	// Проверка первого контрольного разряда (11-й)</Val>
			</Line>
			<Line>
				<Val>	Сумма1 = Число(Сред(ИНН, 1, 1)) * 7 + Число(Сред(ИНН, 2, 1)) * 2 + Число(Сред(ИНН, 3, 1)) * 4 + Число(Сред(ИНН, 4, 1)) * 10 + Число(Сред(ИНН, 5, 1)) * 3 + Число(Сред(ИНН, 6, 1)) * 5 + Число(Сред(ИНН, 7, 1)) * 9 + Число(Сред(ИНН, 8, 1)) * 4 + Число(Сред(ИНН, 9, 1)) * 6 + Число(Сред(ИНН, 10, 1)) * 8;</Val>
			</Line>
			<Line>
				<Val>	Контрольный1 = Сумма1 % 11;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный1 &gt; 9 Тогда</Val>
			</Line>
			<Line>
				<Val>		Контрольный1 = Контрольный1 % 10;</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный1 &lt;&gt; Число(Сред(ИНН, 11, 1)) Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "Неверный контрольный разряд ИНН (11-й знак). Ожидалось: " + Строка(Контрольный1);</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	// Проверка второго контрольного разряда (12-й)</Val>
			</Line>
			<Line>
				<Val>	Сумма2 = Число(Сред(ИНН, 1, 1)) * 3 + Число(Сред(ИНН, 2, 1)) * 7 + Число(Сред(ИНН, 3, 1)) * 2 + Число(Сред(ИНН, 4, 1)) * 4 + Число(Сред(ИНН, 5, 1)) * 10 + Число(Сред(ИНН, 6, 1)) * 3 + Число(Сред(ИНН, 7, 1)) * 5 + Число(Сред(ИНН, 8, 1)) * 9 + Число(Сред(ИНН, 9, 1)) * 4 + Число(Сред(ИНН, 10, 1)) * 6 + Число(Сред(ИНН, 11, 1)) * 8;</Val>
			</Line>
			<Line>
				<Val>	Контрольный2 = Сумма2 % 11;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный2 &gt; 9 Тогда</Val>
			</Line>
			<Line>
				<Val>		Контрольный2 = Контрольный2 % 10;</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>	Если Контрольный2 &lt;&gt; Число(Сред(ИНН, 12, 1)) Тогда</Val>
			</Line>
			<Line>
				<Val>		Возврат "Неверный контрольный разряд ИНН (12-й знак). Ожидалось: " + Строка(Контрольный2);</Val>
			</Line>
			<Line>
				<Val>	КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>КонецЕсли;</Val>
			</Line>
			<Line>
				<Val>Возврат "";</Val>
			</Line>
		</Body>
	</Function>
</Module>
